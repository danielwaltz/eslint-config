{
  "name": "@danielwaltz/eslint-config",
  "type": "module",
  "version": "3.6.1",
  "author": "Daniel Waltz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielwaltz/eslint-config.git"
  },
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepack": "pnpm build",
    "release": "changelogen --release --push --publish",
    "test": "pnpm prepack && pnpm lint && pnpm type-check && pnpm test:publish",
    "test:attw": "pnpx @arethetypeswrong/cli --pack --profile esm-only",
    "test:publint": "pnpx publint",
    "test:publish": "pnpm test:attw && pnpm test:publint",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "prettier": ">=3"
  },
  "dependencies": {
    "@e18e/eslint-plugin": "^0.5.1",
    "@sxzz/eslint-config": "^8.2.1",
    "eslint-flat-config-utils": "^3.2.0",
    "eslint-plugin-erasable-syntax-only": "^0.4.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "~24.13.2",
    "changelogen": "^0.6.2",
    "eslint": "^10.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.5",
    "tsdown": "^0.22.3",
    "typescript": "~6.0.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "warn"
    },
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "warn"
    }
  }
}
