{
  "name": "@danielwaltz/eslint-config",
  "type": "module",
  "version": "3.4.0",
  "packageManager": "pnpm@11.0.4",
  "author": "Daniel Waltz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielwaltz/eslint-config.git"
  },
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepack": "pnpm build",
    "release": "changelogen --release --push --publish",
    "test": "pnpm prepack && pnpm lint && pnpm type-check && pnpm test:publish",
    "test:attw": "pnpm dlx @arethetypeswrong/cli --pack --profile esm-only",
    "test:publint": "pnpm dlx publint",
    "test:publish": "pnpm test:attw && pnpm test:publint",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">=9",
    "prettier": ">=3"
  },
  "dependencies": {
    "@e18e/eslint-plugin": "^0.4.1",
    "@sxzz/eslint-config": "^8.0.0",
    "eslint-flat-config-utils": "^3.2.0",
    "eslint-plugin-erasable-syntax-only": "^0.4.1",
    "eslint-plugin-vuejs-accessibility": "^2.5.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "~24.10.15",
    "changelogen": "^0.6.2",
    "eslint": "^10.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.10",
    "typescript": "~6.0.3"
  }
}
